# Neon Postgres (provisioned via Vercel Marketplace → Storage → Neon)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# SEC EDGAR requires a descriptive User-Agent on every request.
# Format: "Your Name email@example.com"
EDGAR_USER_AGENT="OpenClauses ingest contact@example.com"

# Optional caps for the EDGAR ingestion run
EDGAR_MAX_FILINGS=25
EDGAR_REQUEST_DELAY_MS=120

# LLM clause classifier — pick ONE of the two backends below (or neither, to
# fall back to keyword rules only).
#
# Option A: Direct Groq — free at console.groq.com, no credit card required.
GROQ_API_KEY=
#
# Option B: Vercel AI Gateway — get the key at your Vercel project → AI tab.
# On Vercel itself OIDC handles auth, so this var is unnecessary in production.
AI_GATEWAY_API_KEY=
#
# Optional: override the default model. For direct Groq use the bare model id
# ("llama-3.3-70b-versatile"). For the Gateway use "provider/model" form.
# OPENCLAUSES_CLASSIFIER_MODEL=llama-3.3-70b-versatile
