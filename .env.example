# Neon Postgres (provisioned via Vercel Marketplace → Storage → Neon)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# SEC EDGAR requires a descriptive User-Agent on every request.
# Format: "Your Name email@example.com"
EDGAR_USER_AGENT="OpenClauses ingest contact@example.com"

# Optional caps for the EDGAR ingestion run
EDGAR_MAX_FILINGS=25
EDGAR_REQUEST_DELAY_MS=120

# Vercel AI Gateway — enables the LLM clause classifier during ingestion.
# Get the key from your Vercel project → AI tab. On Vercel itself, OIDC handles
# auth automatically and this var is unnecessary. Leave blank to skip the LLM
# path entirely and use keyword-only classification.
AI_GATEWAY_API_KEY=

# Optional: override the default classifier model (must be a Gateway model id).
# Default is groq/llama-3.3-70b-versatile — fast, free-tier-friendly.
# OPENCLAUSES_CLASSIFIER_MODEL=groq/llama-3.3-70b-versatile
